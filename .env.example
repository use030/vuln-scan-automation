# 스캔 방식입니다. baseline 또는 openapi 중 하나를 사용합니다.
# 띄어쓰기에 유의해 주세요.
SCAN_MODE=

# baseline 모드의 스캔 대상 URL입니다.
TARGET_URL=

# 결과물을 저장할 호스트 디렉터리입니다.
# 비워두면 ./reports 를 사용합니다.
OUTPUT_DIR=./reports

# openapi 모드에서 로컬 OpenAPI 파일을 찾을 호스트 디렉터리와 파일명입니다.
# OPENAPI_TARGET을 비워두면 /zap/openapi/${OPENAPI_FILE} 경로를 자동으로 사용합니다.
OPENAPI_DIR=./openapi
OPENAPI_FILE=openapi.json

# openapi 모드의 스캔 대상입니다. URL이나 컨테이너 내부 파일 경로를 직접 지정할 때 사용합니다.
# 비워두면 OPENAPI_DIR/OPENAPI_FILE 조합으로 로컬 파일을 찾습니다.
# Swagger/OpenAPI URL 예시:
# OPENAPI_TARGET=http://host.docker.internal:8080/v3/api-docs
# 로컬 파일 경로를 직접 지정하는 예시:
# OPENAPI_TARGET=/zap/openapi/openapi.json
OPENAPI_TARGET=

# baseline 모드에서 사용하는 ZAP Spider 최대 실행 시간입니다. 분 단위를 사용합니다. 
ZAP_MAX_DURATION=1

# 보안 게이트의 threshold입니다. none, low, medium, high 중 하나를 사용합니다.
# 예: medium으로 설정하면 Medium 이상 finding이 있을 때 실패 처리합니다.
FAIL_ON=none

# 인증이 필요한 서비스 스캔을 위한 true/false 설정입니다. 
# 이미 발급받은 엑세스 토큰이나 쿠키를 ZAP 요청에 주입합니다.
# 이 프로젝트는 아이디/비밀번호 로그인 자동화를 수행하지 않습니다.
AUTH_ENABLED=false

# Bearer 토큰 예시
# AUTH_HEADER_1_NAME=Authorization
# AUTH_HEADER_1_VALUE=Bearer your-access-token
AUTH_HEADER_1_NAME=
AUTH_HEADER_1_VALUE=

# 추가 헤더가 필요할 때 사용
# 예: X-API-Key, X-CSRF-Token, X-Auth-Token 등
AUTH_HEADER_2_NAME=
AUTH_HEADER_2_VALUE=
AUTH_HEADER_3_NAME=
AUTH_HEADER_3_VALUE=

# 쿠키 기반 인증 예시:
# AUTH_COOKIE=sessionid=abc123; csrftoken=def456
AUTH_COOKIE=
